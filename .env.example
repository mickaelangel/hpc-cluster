# =============================================================================
# Variables d'environnement pour le cluster HPC (template)
# =============================================================================
# Copier ce fichier en .env et adapter les valeurs.
#
# ⚠️  MODE DÉMO (LAB) : Les valeurs ci-dessous sont pour test/local uniquement.
#     NE PAS UTILISER EN PRODUCTION.
#
# Pour la production : définir des mots de passe forts et ne jamais commiter .env
# =============================================================================

# --- Mode : demo | prod ---
# demo = identifiants faciles (documentés), root SSH autorisé pour les conteneurs
# prod = exige des secrets via .env, pas de valeurs par défaut démo
HPC_MODE=demo

# --- Grafana ---
# Utilisateur admin (démo : admin)
GF_SECURITY_ADMIN_USER=admin
# Mot de passe admin (DÉMO : demo-hpc-2024 — NE PAS UTILISER EN PROD)
GF_SECURITY_ADMIN_PASSWORD=demo-hpc-2024

# --- InfluxDB (init one-shot) ---
DOCKER_INFLUXDB_INIT_USERNAME=admin
# Mot de passe admin InfluxDB (DÉMO : admin1234 — NE PAS UTILISER EN PROD)
DOCKER_INFLUXDB_INIT_PASSWORD=admin1234

# --- Optionnel : LDAP/FreeIPA (scripts) ---
# LDAP_PASSWORD=
# KERBEROS_ADMIN_PASSWORD=
# FREEIPA_ADMIN_PASSWORD=
